# Copy to .env and set your MySQL connection string.
#
# --- Production / VPS (e.g. AWS EC2) ---
# - Set the SAME variables on the host (pm2 ecosystem, Docker env, systemd) — .env is not copied by git.
# - DATABASE_URL must reach MySQL from the server (security group / bind-address 0.0.0.0 or RDS).
# - Run: npx prisma migrate deploy   after each deploy so tables like customer_phone_otps exist.
# - JWT_SECRET is required in production (OTP hashing uses it if OTP_HMAC_SECRET is unset).
# - FAST2SMS_API_KEY: if Fast2SMS "IP security" is on, whitelist your server's public IP.
# - Outbound HTTPS (443) must be allowed for www.fast2sms.com.
# Application port (required; no default in code). Used when running node app.js / npm run dev / npm run start.
PORT=3004

# Prisma (MySQL) — production-grade multi-vendor e-commerce schema.
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Auth (required in production). Use a long random string (e.g. openssl rand -base64 32).
JWT_SECRET="your-secret-at-least-32-characters-long"
# Optional: JWT_EXPIRES_IN="7d" | AUTH_COOKIE_NAME="auth_token"
# For HTTP deployment (e.g. http://IP:3004), set AUTH_COOKIE_SECURE=false so login works.
# AUTH_COOKIE_SECURE=false

# Email (customer sign-up confirmation, vendor verification, forgot-password). Use SMTP_HOST (not SWMTP_HOST).
# Brevo: use smtp-relay.brevo.com, create SMTP key in Brevo → SMTP & API → SMTP.
# SMTP_FROM must be a verified sender in Brevo. Without these, verification/reset emails are not sent.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Base URL of the app (used for emails and auth cookie). Use http:// for HTTP deployment (e.g. http://13.127.37.238:3004).
APP_URL="http://localhost:3004"

# Razorpay (for receiving Card/UPI payments). Get keys from https://dashboard.razorpay.com/app/keys (use Test Mode).
# IMPORTANT: NEXT_PUBLIC_RAZORPAY_KEY_ID must be the SAME value as RAZORPAY_KEY_ID (not a placeholder).
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx
# Public key for browser — must match RAZORPAY_KEY_ID exactly (e.g. rzp_test_AbCdEf...)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxx

# Super Admin Panel — backend API URL (default: http://localhost:4000). Used by /superadmin UI.
# NEXT_PUBLIC_SUPER_ADMIN_API_URL=http://localhost:4000

# --- Fast2SMS: customer login OTP (India) — Dashboard → Dev API → API key ---
# Paste your key after FAST2SMS_API_KEY= (no quotes). Restart the app after saving.
# Optional alias: FAST2SMS_AUTHORIZATION= (same value as API key).
FAST2SMS_API_KEY=
# q = Quick SMS (easiest; may NOT deliver to DND numbers). otp = OTP API (needs website verification in dashboard).
# dlt = transactional (best for production): set FAST2SMS_SENDER_ID, FAST2SMS_MESSAGE_ID, FAST2SMS_VARIABLES_VALUES.
FAST2SMS_ROUTE=q
# If otp is blocked until verification, we auto-retry with q. Disable: FAST2SMS_OTP_FALLBACK_Q=false
# Optional: FAST2SMS_FLASH=1 — flash SMS (pops on screen; use briefly for testing only).
# Optional SMS fallback: TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_PHONE_NUMBER
