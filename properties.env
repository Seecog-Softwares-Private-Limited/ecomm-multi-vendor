# =============================================================================
# Environment template — safe to commit to git.
# Copy this file to .env and set your real values. Never commit .env.
#   Windows: copy properties.env .env
#   Mac/Linux: cp properties.env .env
# =============================================================================

# Application port (used by app.js and Next.js). No hardcoding in code.
PORT=3005

# Prisma (MySQL) — production-grade multi-vendor e-commerce schema.
DATABASE_URL="mysql://dbmasteruser:e%5E3ib6%2C%23~O%3CvQw%3Eu%5B9YNXmg-O%5E4XQs%26S@ls-fac214460288ee0a44d4313d95a0fe5218cd91fd.clg862gaklds.ap-south-1.rds.amazonaws.com:3306/markethub"
# Auth (required in production). Use a long random string (e.g. openssl rand -base64 32).
JWT_SECRET="your-secret-at-least-32-characters-long"
# Optional: JWT_EXPIRES_IN="7d" | AUTH_COOKIE_NAME="auth_token"

# Email (vendor verification). Use SMTP_HOST (not SWMTP_HOST).
# Brevo: use smtp-relay.brevo.com, create SMTP key in Brevo → SMTP & API → SMTP.
# SMTP_FROM must be a verified sender in Brevo.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
APP_URL="http://13.234.232.60:3004"

# AWS SNS — customer login OTP (SMS). Create an IAM user with sns:Publish; use ap-south-1 or your SMS region.
# If Publish succeeds but no SMS arrives: SMS sandbox (verify destination in SNS console or exit sandbox),
# monthly spend limit ($0 blocks sends), India DLT rules — see AWS SNS SMS documentation.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional temporary credentials:
# AWS_SESSION_TOKEN=
# Optional: Transactional (default) or Promotional
# AWS_SNS_SMS_TYPE=Transactional
# Optional sender ID (where supported / registered, e.g. India):
# AWS_SNS_SMS_SENDER_ID=
