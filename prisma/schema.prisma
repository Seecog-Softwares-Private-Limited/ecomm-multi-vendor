// MarketHub / Indo-Vyapar — Production Prisma Schema (MySQL)
// Based on approved domain model. UUID PKs, soft delete, full relations, indexes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING_VERIFICATION
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
  ON_HOLD
}

enum ProductStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  INACTIVE
}

enum OrderStatus {
  PLACED
  PAYMENT_CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum OrderItemStatus {
  NEW
  ACCEPTED
  REJECTED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMode {
  PREPAID
  COD
  WALLET
  CARD
  UPI
  OTHER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KYCDocumentType {
  PAN
  GST_CERTIFICATE
  ADDRESS_PROOF
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
}

enum PayoutStatus {
  PENDING
  PAID
  FAILED
}

enum NotificationType {
  SYSTEM
  ORDER
  SELLER
  PAYMENT
  RETURN
}

enum ReturnPolicy {
  DAYS_7
  DAYS_15
  DAYS_30
  NO_RETURN
}

// =============================================================================
// ACTORS / IDENTITY
// =============================================================================

model User {
  id           String    @id @default(uuid()) @db.Char(36)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  firstName    String?   @map("first_name") @db.VarChar(100)
  lastName     String?   @map("last_name") @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)

  addresses           Address[]
  orders              Order[]
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]
  supportTickets      SupportTicket[]
  reviews             Review[]
  notifications       Notification[]
  productQuestionsAsked ProductQuestion[] @relation("ProductQuestionAskedBy")

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Admin {
  id           String    @id @default(uuid()) @db.Char(36)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  name         String?   @db.VarChar(255)
  phone        String?   @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)

  notifications Notification[]

  @@index([email])
  @@index([deletedAt])
  @@map("admins")
}

model Seller {
  id                        String       @id @default(uuid()) @db.Char(36)
  email                     String       @unique @db.VarChar(255)
  passwordHash              String       @map("password_hash") @db.VarChar(255)
  businessName              String       @map("business_name") @db.VarChar(255)
  ownerName                 String       @map("owner_name") @db.VarChar(255)
  phone                     String?      @db.VarChar(20)
  businessAddress           String?      @map("business_address") @db.VarChar(500)
  profileExtras             String?      @map("profile_extras") @db.Text
  emailVerified             Boolean      @default(false) @map("email_verified")
  verificationToken         String?      @map("verification_token") @db.VarChar(255)
  verificationTokenExpires  DateTime?    @map("verification_token_expires") @db.DateTime(3)
  passwordResetToken        String?      @map("password_reset_token") @db.VarChar(255)
  passwordResetExpires      DateTime?    @map("password_reset_expires") @db.DateTime(3)
  status                    SellerStatus @default(PENDING_VERIFICATION)
  statusReason              String?      @map("status_reason") @db.Text
  primaryCategoryId         String?      @map("primary_category_id") @db.Char(36)
  createdAt                 DateTime     @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt                 DateTime     @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt                 DateTime?    @map("deleted_at") @db.DateTime(3)

  primaryCategory           Category?    @relation("SellerPrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  products                  Product[]
  orderItems                OrderItem[]
  kycDocuments              KYCDocument[]
  bankAccounts               BankAccount[]
  vendorDocuments            VendorDocument[]
  settlements                Settlement[]
  payouts                    Payout[]
  returns                    Return[]
  notifications              Notification[]
  questionsAnswered          ProductQuestion[] @relation("ProductQuestionAnsweredBy")
  supportTickets            VendorSupportTicket[]

  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([primaryCategoryId])
  @@map("sellers")
}

model VendorSupportTicket {
  id        String   @id @default(uuid()) @db.Char(36)
  sellerId  String   @map("seller_id") @db.Char(36)
  subject   String   @db.VarChar(500)
  category  String   @db.VarChar(100)
  message   String   @db.Text
  status    SupportTicketStatus @default(OPEN)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("vendor_support_tickets")
}

// =============================================================================
// CATALOG
// =============================================================================

model Category {
  id         String    @id @default(uuid()) @db.Char(36)
  slug       String    @unique @db.VarChar(100)
  name       String    @db.VarChar(255)
  sortOrder  Int?      @map("sort_order") @default(0) @db.Int
  createdAt  DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(3)

  subCategories            SubCategory[]
  products                 Product[]
  documentRequirements     CategoryDocumentRequirement[]
  primaryCategorySellers   Seller[] @relation("SellerPrimaryCategory")

  @@index([slug])
  @@index([deletedAt])
  @@map("categories")
}

model CategoryDocumentRequirement {
  id          String   @id @default(uuid()) @db.Char(36)
  categoryId  String   @map("category_id") @db.Char(36)
  documentName String  @map("document_name") @db.VarChar(255)
  isRequired  Boolean  @default(true) @map("is_required") @db.TinyInt
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([deletedAt])
  @@map("category_document_requirements")
}

model VendorDocument {
  id           String   @id @default(uuid()) @db.Char(36)
  sellerId     String   @map("seller_id") @db.Char(36)
  documentName String   @map("document_name") @db.VarChar(255)
  documentUrl  String   @map("document_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime? @map("deleted_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, documentName])
  @@index([sellerId])
  @@index([deletedAt])
  @@map("vendor_documents")
}

model SubCategory {
  id         String   @id @default(uuid()) @db.Char(36)
  categoryId String  @map("category_id") @db.Char(36)
  slug      String   @db.VarChar(100)
  name      String   @db.VarChar(255)
  sortOrder Int?     @map("sort_order") @default(0) @db.Int
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([categoryId, slug])
  @@index([categoryId])
  @@index([deletedAt])
  @@map("sub_categories")
}

model Product {
  id            String        @id @default(uuid()) @db.Char(36)
  sellerId      String        @map("seller_id") @db.Char(36)
  categoryId    String        @map("category_id") @db.Char(36)
  subCategoryId String        @map("sub_category_id") @db.Char(36)
  name          String        @db.VarChar(500)
  description   String?       @db.Text
  sku           String        @db.VarChar(100)
  mrp           Decimal       @db.Decimal(12, 2)
  sellingPrice  Decimal       @map("selling_price") @db.Decimal(12, 2)
  gstPercent    Decimal?      @map("gst_percent") @db.Decimal(5, 2)
  stock         Int           @default(0) @db.Int
  returnPolicy  ReturnPolicy  @default(DAYS_7) @map("return_policy")
  status        ProductStatus @default(DRAFT)
  avgRating     Decimal?      @map("avg_rating") @db.Decimal(3, 2)
  reviewCount   Int?          @map("review_count") @default(0) @db.Int
  createdAt     DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt     DateTime?     @map("deleted_at") @db.DateTime(3)

  seller              Seller                 @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  category            Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subCategory         SubCategory            @relation(fields: [subCategoryId], references: [id], onDelete: Restrict)
  images              ProductImage[]
  specifications      ProductSpecification[]
  variations          ProductVariation[]
  reviews             Review[]
  questions           ProductQuestion[]
  orderItems          OrderItem[]
  cartItems           CartItem[]
  wishlistItems       WishlistItem[]

  @@unique([sellerId, sku])
  @@index([sellerId])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("products")
}

model ProductImage {
  id        String    @id @default(uuid()) @db.Char(36)
  productId String    @map("product_id") @db.Char(36)
  url       String    @db.VarChar(500)
  sortOrder Int?      @map("sort_order") @default(0) @db.Int
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([deletedAt])
  @@map("product_images")
}

model ProductSpecification {
  id        String    @id @default(uuid()) @db.Char(36)
  productId String    @map("product_id") @db.Char(36)
  key       String    @db.VarChar(100)
  value     String    @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([deletedAt])
  @@map("product_specifications")
}

model ProductVariation {
  id        String    @id @default(uuid()) @db.Char(36)
  productId String    @map("product_id") @db.Char(36)
  name      String    @db.VarChar(100)
  values    Json      @db.Json
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([deletedAt])
  @@map("product_variations")
}

// =============================================================================
// USER DATA
// =============================================================================

model Address {
  id        String      @id @default(uuid()) @db.Char(36)
  userId    String      @map("user_id") @db.Char(36)
  type      AddressType @default(HOME)
  fullName  String      @map("full_name") @db.VarChar(255)
  line1     String      @db.VarChar(255)
  line2     String?     @db.VarChar(255)
  city      String      @db.VarChar(100)
  state     String      @db.VarChar(100)
  pincode   String      @db.VarChar(20)
  phone     String      @db.VarChar(20)
  isDefault Boolean    @default(false) @map("is_default")
  createdAt DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime?  @map("deleted_at") @db.DateTime(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@index([userId, isDefault])
  @@index([deletedAt])
  @@map("addresses")
}

model CartItem {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @map("user_id") @db.Char(36)
  productId  String   @map("product_id") @db.Char(36)
  quantity   Int      @default(1) @db.Int
  variantKey String?  @map("variant_key") @db.VarChar(255)
  createdAt  DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt  DateTime? @map("deleted_at") @db.DateTime(3)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantKey])
  @@index([userId])
  @@index([productId])
  @@index([deletedAt])
  @@map("cart_items")
}

model WishlistItem {
  id        String    @id @default(uuid()) @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  productId String    @map("product_id") @db.Char(36)
  variantKey String?  @map("variant_key") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@index([deletedAt])
  @@map("wishlist_items")
}

// =============================================================================
// COMMERCE — ORDERS
// =============================================================================

model Order {
  id              String   @id @default(uuid()) @db.Char(36)
  userId          String   @map("user_id") @db.Char(36)
  shippingAddressId String @map("shipping_address_id") @db.Char(36)
  couponId        String?  @map("coupon_id") @db.Char(36)
  status          OrderStatus @default(PLACED)
  totalAmount     Decimal  @map("total_amount") @db.Decimal(12, 2)
  discountAmount  Decimal? @map("discount_amount") @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal? @map("tax_amount") @default(0) @db.Decimal(12, 2)
  shippingAmount  Decimal? @map("shipping_amount") @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  user              User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  shippingAddress   Address            @relation(fields: [shippingAddressId], references: [id], onDelete: Restrict)
  coupon             Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  payments           Payment[]
  statusEvents       OrderStatusEvent[]
  returns            Return[]
  supportTickets     SupportTicket[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id              String          @id @default(uuid()) @db.Char(36)
  orderId         String          @map("order_id") @db.Char(36)
  productId       String          @map("product_id") @db.Char(36)
  sellerId        String          @map("seller_id") @db.Char(36)
  quantity        Int             @db.Int
  unitPrice       Decimal         @map("unit_price") @db.Decimal(12, 2)
  totalPrice      Decimal         @map("total_price") @db.Decimal(12, 2)
  status          OrderItemStatus  @default(NEW)
  variantSnapshot Json?           @map("variant_snapshot") @db.Json
  sku             String?         @db.VarChar(100)
  commissionPercent Decimal?      @map("commission_percent") @db.Decimal(5, 2)
  commissionAmount  Decimal?      @map("commission_amount") @db.Decimal(12, 2)
  netPayable       Decimal?       @map("net_payable") @db.Decimal(12, 2)
  createdAt        DateTime       @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.DateTime(3)

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  seller   Seller   @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  returnItems ReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@index([sellerId])
  @@index([status])
  @@map("order_items")
}

model OrderStatusEvent {
  id        String      @id @default(uuid()) @db.Char(36)
  orderId   String      @map("order_id") @db.Char(36)
  status    OrderStatus
  note      String?     @db.VarChar(500)
  occurredAt DateTime   @default(now()) @map("occurred_at") @db.DateTime(3)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([orderId, occurredAt])
  @@map("order_status_events")
}

model Payment {
  id            String        @id @default(uuid()) @db.Char(36)
  orderId       String        @map("order_id") @db.Char(36)
  mode          PaymentMode
  status        PaymentStatus @default(PENDING)
  amount        Decimal       @db.Decimal(12, 2)
  transactionId String?       @map("transaction_id") @db.VarChar(255)
  paidAt        DateTime?     @map("paid_at") @db.DateTime(3)
  createdAt     DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.DateTime(3)

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@index([transactionId])
  @@map("payments")
}

// =============================================================================
// COUPON
// =============================================================================

model Coupon {
  id            String    @id @default(uuid()) @db.Char(36)
  code          String    @unique @db.VarChar(50)
  discountType  String    @map("discount_type") @db.VarChar(20)
  discountValue Decimal   @map("discount_value") @db.Decimal(10, 2)
  validFrom     DateTime  @map("valid_from") @db.DateTime(3)
  validTo       DateTime  @map("valid_to") @db.DateTime(3)
  maxUses       Int?      @map("max_uses") @db.Int
  usedCount     Int?      @map("used_count") @default(0) @db.Int
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt     DateTime? @map("deleted_at") @db.DateTime(3)

  orders Order[]

  @@index([code])
  @@index([validFrom, validTo])
  @@index([deletedAt])
  @@map("coupons")
}

// =============================================================================
// RETURNS
// =============================================================================

model Return {
  id          String      @id @default(uuid()) @db.Char(36)
  orderId     String      @map("order_id") @db.Char(36)
  sellerId    String      @map("seller_id") @db.Char(36)
  totalAmount Decimal    @map("total_amount") @db.Decimal(12, 2)
  reason      String      @db.VarChar(500)
  status      ReturnStatus @default(PENDING)
  createdAt   DateTime   @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime?  @map("deleted_at") @db.DateTime(3)

  order       Order        @relation(fields: [orderId], references: [id], onDelete: Restrict)
  seller      Seller       @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  returnItems ReturnItem[]

  @@index([orderId])
  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("returns")
}

model ReturnItem {
  id          String   @id @default(uuid()) @db.Char(36)
  returnId    String   @map("return_id") @db.Char(36)
  orderItemId String  @map("order_item_id") @db.Char(36)
  quantity    Int     @db.Int
  refundAmount Decimal @map("refund_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  return    Return    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@unique([returnId, orderItemId])
  @@index([returnId])
  @@index([orderItemId])
  @@map("return_items")
}

// =============================================================================
// SUPPORT
// =============================================================================

model SupportTicket {
  id         String              @id @default(uuid()) @db.Char(36)
  userId     String              @map("user_id") @db.Char(36)
  orderId    String?             @map("order_id") @db.Char(36)
  subject    String              @db.VarChar(500)
  status     SupportTicketStatus @default(OPEN)
  lastUpdateAt DateTime?         @map("last_update_at") @db.DateTime(3)
  createdAt  DateTime            @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt  DateTime            @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt  DateTime?          @map("deleted_at") @db.DateTime(3)

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("support_tickets")
}

// =============================================================================
// REVIEWS & Q&A
// =============================================================================

model Review {
  id        String    @id @default(uuid()) @db.Char(36)
  productId String    @map("product_id") @db.Char(36)
  userId    String    @map("user_id") @db.Char(36)
  rating    Int       @db.Int
  comment   String?   @db.Text
  verified  Boolean   @default(false)
  helpfulCount Int?   @map("helpful_count") @default(0) @db.Int
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt DateTime? @map("deleted_at") @db.DateTime(3)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("reviews")
}

model ProductQuestion {
  id          String    @id @default(uuid()) @db.Char(36)
  productId   String    @map("product_id") @db.Char(36)
  question    String    @db.Text
  answer      String?   @db.Text
  askedByUserId  String? @map("asked_by_user_id") @db.Char(36)
  answeredBySellerId String? @map("answered_by_seller_id") @db.Char(36)
  helpfulCount Int?     @map("helpful_count") @default(0) @db.Int
  createdAt   DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt   DateTime? @map("deleted_at") @db.DateTime(3)

  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  askedByUser   User?   @relation("ProductQuestionAskedBy", fields: [askedByUserId], references: [id], onDelete: SetNull)
  answeredBySeller Seller? @relation("ProductQuestionAnsweredBy", fields: [answeredBySellerId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([askedByUserId])
  @@index([answeredBySellerId])
  @@index([deletedAt])
  @@map("product_questions")
}

// =============================================================================
// SELLER LIFECYCLE — KYC & BANK
// =============================================================================

model KYCDocument {
  id           String          @id @default(uuid()) @db.Char(36)
  sellerId     String          @map("seller_id") @db.Char(36)
  documentType KYCDocumentType @map("document_type")
  identifier   String?         @db.VarChar(100)
  fileUrl      String?         @map("file_url") @db.VarChar(500)
  status       KYCStatus       @default(PENDING)
  createdAt    DateTime        @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt    DateTime?       @map("deleted_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@unique([sellerId, documentType])
  @@index([sellerId])
  @@index([status])
  @@index([deletedAt])
  @@map("kyc_documents")
}

model BankAccount {
  id              String    @id @default(uuid()) @db.Char(36)
  sellerId        String    @map("seller_id") @db.Char(36)
  bankName        String    @map("bank_name") @db.VarChar(255)
  accountHolderName String  @map("account_holder_name") @db.VarChar(255)
  accountNumber   String    @map("account_number") @db.VarChar(100)
  ifscCode        String    @map("ifsc_code") @db.VarChar(20)
  isPrimary       Boolean   @default(false) @map("is_primary")
  createdAt       DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt       DateTime? @map("deleted_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
  @@index([deletedAt])
  @@map("bank_accounts")
}

// =============================================================================
// SETTLEMENT & PAYOUT
// =============================================================================

model Settlement {
  id             String           @id @default(uuid()) @db.Char(36)
  sellerId       String           @map("seller_id") @db.Char(36)
  periodStart    DateTime         @map("period_start") @db.Date
  periodEnd      DateTime         @map("period_end") @db.Date
  revenue        Decimal          @db.Decimal(14, 2)
  commissionAmount Decimal        @map("commission_amount") @db.Decimal(14, 2)
  payoutAmount   Decimal          @map("payout_amount") @db.Decimal(14, 2)
  status         SettlementStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@unique([sellerId, periodStart, periodEnd])
  @@index([sellerId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("settlements")
}

model Payout {
  id          String       @id @default(uuid()) @db.Char(36)
  sellerId    String       @map("seller_id") @db.Char(36)
  periodStart DateTime     @map("period_start") @db.Date
  periodEnd   DateTime     @map("period_end") @db.Date
  amount      Decimal      @db.Decimal(14, 2)
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?    @map("paid_at") @db.DateTime(3)
  reference   String?      @db.VarChar(255)
  ordersCount Int?         @map("orders_count") @db.Int
  createdAt   DateTime     @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.DateTime(3)

  seller Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([sellerId])
  @@index([status])
  @@index([paidAt])
  @@map("payouts")
}

// =============================================================================
// NOTIFICATIONS (polymorphic recipient: user, seller, or admin)
// =============================================================================

model Notification {
  id             String           @id @default(uuid()) @db.Char(36)
  type           NotificationType
  title          String           @db.VarChar(255)
  message        String           @db.Text
  userId         String?          @map("user_id") @db.Char(36)
  sellerId       String?          @map("seller_id") @db.Char(36)
  adminId        String?          @map("admin_id") @db.Char(36)
  read           Boolean          @default(false)
  readAt         DateTime?        @map("read_at") @db.DateTime(3)
  createdAt      DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.DateTime(3)
  deletedAt      DateTime?        @map("deleted_at") @db.DateTime(3)

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  seller Seller? @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  admin   Admin?  @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sellerId])
  @@index([adminId])
  @@index([read])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("notifications")
}
